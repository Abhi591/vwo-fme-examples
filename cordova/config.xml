<?xml version='1.0' encoding='utf-8'?>
<widget id="com.example.fmeexample" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>VWO FME Cordova Example</name>
    <description>
        A sample application demonstrating VWO Feature Management and Experimentation (FME) integration.
    </description>
    <author email="dev@cordova.apache.org" href="http://cordova.io">
        VWO FME Example Team
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-targetSdkVersion" value="33" />
        <preference name="android-compileSdkVersion" value="33" />
    </platform>
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
    </platform>
    <platform name="browser">
        <preference name="DisallowOverscroll" value="true" />
    </platform>
    <engine name="android" spec="~12.0.0" />
    <engine name="ios" spec="~7.0.0" />
    <engine name="browser" spec="~6.0.0" />
</widget>
